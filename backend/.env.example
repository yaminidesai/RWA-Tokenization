# Copy this to .env and fill in values before running

# ── Application ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rwa_platform

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h

# ── Canton Ledger (HTTP JSON API) ────────────────────────────
# Start the JSON API with: daml json-api --ledger-host localhost --ledger-port 6865 --http-port 7575
CANTON_JSON_API_URL=http://localhost:7575

# The bank's Canton party ID — printed by bootstrap.canton on first run
# Example: EscrowBank::122abc123def456...
BANK_PARTY_ID=EscrowBank::REPLACE_WITH_ACTUAL_PARTY_ID

# ── Mock Integration Flags ───────────────────────────────────
# Set to "true" to use real providers (requires credentials below)
USE_REAL_JUMIO=false
USE_REAL_DTC=false
USE_REAL_FEDWIRE=false

# ── Jumio KYC (production only) ──────────────────────────────
# JUMIO_API_TOKEN=
# JUMIO_API_SECRET=
# JUMIO_BASE_URL=https://api.jumio.com

# ── DTC / SWIFT (production only — requires bank credentials) ─
# DTC_PARTICIPANT_ID=
# SWIFT_BIC=
# SWIFT_API_KEY=

# ── Fedwire (production only — requires Fed account) ─────────
# FEDWIRE_ROUTING_NUMBER=
# FEDWIRE_ACCOUNT_NUMBER=
