-- ============================================================
-- Test.RWATests — Full Lifecycle Test Suite
-- ============================================================
--
-- End-to-end coverage of every contract template and every choice
-- across the four RWA modules. Each script runs on its own ledger
-- and mirrors the production sequence used by the off-chain
-- KYC / Custody / Minting / Transfer / Redemption services:
--
--   1. KYC onboarding         (KYCInvitation -> AcceptKYCInvitation
--                              -> InvestorKYC -> ApproveKYC)
--   2. Custody attestation    (CustodyRecord with DTC MT545 ref)
--   3. Purchase + mint        (EscrowRequest -> ApproveRequest ->
--                              ConfirmCustodyAndMint + RecordMinting +
--                              TokenizedBond)
--   4. Coupon distribution    (RecordCouponPayment -> CouponPaymentRecord)
--   5. Secondary transfer     (TransferOwnership with dual control)
--   6. Partial position split (SplitTransfer preserves units)
--   7. Redemption + burn      (InitiateRedemption -> ApproveRedemption +
--                              BurnToken + RecordRedemption)
--
-- The 1:1 backing invariant, the dual-control transfer model, the
-- nonconsuming redemption choice, and the rejection / cancellation
-- audit paths are each verified explicitly.
module Test.RWATests where

import DA.Date
import Daml.Script

import RWA.Types
import RWA.KYC
import RWA.AssetCustody
import RWA.EscrowRequest
import RWA.TokenizedBond
import Test.Setup

-- ============================================================
-- Test 1 — End-to-end: KYC -> custody -> mint -> coupon ->
--          transfer -> redeem -> burn
-- ============================================================
testFullLifecycle : Script ()
testFullLifecycle = do
  TestParties{..} <- allocateTestParties

  -- (1) KYC invitation flow for investor1, plus approved KYC for both investors
  inviteCid <- submit bank do
    createCmd KYCInvitation with
      investor    = investor1
      escrowBank  = bank
      regulator   = regulator
      invitedDate = date 2026 Jan 2
  submit investor1 do
    exerciseCmd inviteCid AcceptKYCInvitation

  _ <- setupApprovedKYC bank regulator investor1
  _ <- setupApprovedKYC bank regulator investor2

  -- (2) Bank attests it holds 1000 units of the T-Note at DTC
  custodyCid <- setupCustodyRecord bank regulator 1000.0

  -- (3) Mint 100 units to investor1
  (bondCid, custodyCid') <-
    mintBond bank regulator investor1 custodyCid 100.0 "DTC-MT545-MINT-001"

  Some custody <- queryContractId bank custodyCid'
  assertMsg "Backing: 100 units minted" (custody.totalMintedUnits == 100.0)
  assertMsg "Backing: custody quantity unchanged" (custody.quantity == 1000.0)
  assertMsg "Backing invariant holds" (custody.totalMintedUnits <= custody.quantity)

  -- (4) Bank records a semiannual coupon payment to investor1
  couponCid <- submit bank do
    exerciseCmd bondCid RecordCouponPayment with
      couponDate   = date 2026 Jul 15
      couponAmount = MonetaryAmount with amount = 2250.0; currency = "USD"
      paymentRef   = "FEDWIRE-CPN-001"
  Some coupon <- queryContractId investor1 couponCid
  assertMsg "Coupon paid to investor1" (coupon.investor == investor1)
  assertMsg "Coupon amount preserved"  (coupon.couponAmount.amount == 2250.0)

  -- (5) Dual-control transfer: investor1 -> investor2
  bondCid2 <- submitMulti [investor1, bank] [] do
    exerciseCmd bondCid TransferOwnership with
      newOwner    = investor2
      transferRef = "XFER-001"
  Some bond <- queryContractId investor2 bondCid2
  assertMsg "Owner is now investor2"     (bond.currentOwner == investor2)
  assertMsg "Audit trail recorded"       (bond.transferHistory == ["XFER-001"])
  assertMsg "Units unchanged on transfer" (bond.units == 100.0)

  -- (6) Redemption via nonconsuming InitiateRedemption, then atomic
  -- compose of ApproveRedemption + BurnToken + RecordRedemption
  redCid <- submit investor2 do
    exerciseCmd bondCid2 InitiateRedemption
  submit bank do
    exerciseCmd redCid ApproveRedemption with
      redemptionAmount = MonetaryAmount with amount = 100000.0; currency = "USD"
      paymentRef       = "FEDWIRE-REDEEM-001"
  submit bank do
    exerciseCmd bondCid2 BurnToken
  custodyCid'' <- submit bank do
    exerciseCmd custodyCid' RecordRedemption with
      redeemedUnits = 100.0
      redemptionRef = "DTC-MAT-001"

  -- Verify post-redemption state
  noBond <- queryContractId investor2 bondCid2
  assertMsg "Bond burned" (noBond == None)
  Some custodyFinal <- queryContractId bank custodyCid''
  assertMsg "Minted decremented"      (custodyFinal.totalMintedUnits == 0.0)
  assertMsg "Quantity decremented"    (custodyFinal.quantity == 900.0)
  assertMsg "Backing invariant holds" (custodyFinal.totalMintedUnits <= custodyFinal.quantity)
  pure ()

-- ============================================================
-- Test 2 — SplitTransfer preserves total units and ownership split
-- ============================================================
testSplitTransfer : Script ()
testSplitTransfer = do
  TestParties{..} <- allocateTestParties
  _ <- setupApprovedKYC bank regulator investor1
  _ <- setupApprovedKYC bank regulator investor2

  custodyCid <- setupCustodyRecord bank regulator 1000.0
  (bondCid, _) <-
    mintBond bank regulator investor1 custodyCid 200.0 "DTC-MT545-SPL-001"

  (remainderCid, transferredCid) <- submitMulti [investor1, bank] [] do
    exerciseCmd bondCid SplitTransfer with
      newOwner      = investor2
      transferUnits = 75.0
      transferRef   = "XFER-SPLIT-001"

  Some remainder   <- queryContractId investor1 remainderCid
  Some transferred <- queryContractId investor2 transferredCid
  assertMsg "Remainder owner"    (remainder.currentOwner == investor1)
  assertMsg "Transferred owner"  (transferred.currentOwner == investor2)
  assertMsg "Remainder units"    (remainder.units == 125.0)
  assertMsg "Transferred units"  (transferred.units == 75.0)
  assertMsg "Sum preserved"      (remainder.units + transferred.units == 200.0)
  assertMsg "Split history kept" (transferred.transferHistory == ["XFER-SPLIT-001"])
  pure ()

-- ============================================================
-- Test 3 — Over-issuance is structurally impossible
-- ============================================================
-- The CustodyRecord ensure clause and RecordMinting assertion together
-- guarantee that no transaction can leave totalMintedUnits > quantity.
testCannotOverMint : Script ()
testCannotOverMint = do
  TestParties{..} <- allocateTestParties
  custodyCid <- setupCustodyRecord bank regulator 50.0
  submitMustFail bank do
    exerciseCmd custodyCid RecordMinting with mintedUnits = 100.0

-- ============================================================
-- Test 4 — Rejected purchase produces an immutable audit record
-- ============================================================
testRejectedPurchase : Script ()
testRejectedPurchase = do
  TestParties{..} <- allocateTestParties
  _ <- setupApprovedKYC bank regulator investor1

  reqCid <- submitMulti [bank, investor1] [] do
    createCmd EscrowRequest with
      investor           = investor1
      escrowBank         = bank
      regulator          = regulator
      metadata           = sampleBondMetadata
      requestedUnits     = 10.0
      maxPurchasePrice   = MonetaryAmount with amount = 10000.0; currency = "USD"
      requestDate        = date 2026 Feb 1
      investorAccountRef = "ACCT-REJ-001"
      notes              = ""
  rejCid <- submit bank do
    exerciseCmd reqCid RejectRequest with
      rejectionReason = "Bond unavailable from primary dealer at price ceiling"

  Some rej <- queryContractId regulator rejCid
  assertMsg "Rejection visible to regulator"
    (rej.rejectionReason == "Bond unavailable from primary dealer at price ceiling")
  assertMsg "Audit record preserves units" (rej.requestedUnits == 10.0)
  pure ()

-- ============================================================
-- Test 5 — Empty rejection reason is rejected (compliance)
-- ============================================================
testRejectionReasonRequired : Script ()
testRejectionReasonRequired = do
  TestParties{..} <- allocateTestParties
  _ <- setupApprovedKYC bank regulator investor1
  reqCid <- submitMulti [bank, investor1] [] do
    createCmd EscrowRequest with
      investor           = investor1
      escrowBank         = bank
      regulator          = regulator
      metadata           = sampleBondMetadata
      requestedUnits     = 10.0
      maxPurchasePrice   = MonetaryAmount with amount = 10000.0; currency = "USD"
      requestDate        = date 2026 Feb 1
      investorAccountRef = "ACCT-002"
      notes              = ""
  submitMustFail bank do
    exerciseCmd reqCid RejectRequest with rejectionReason = ""

-- ============================================================
-- Test 6 — KYC renewal extends expiry; revocation archives the cert
-- ============================================================
testKYCLifecycle : Script ()
testKYCLifecycle = do
  TestParties{..} <- allocateTestParties
  kycCid <- setupApprovedKYC bank regulator investor1

  renewedCid <- submit bank do
    exerciseCmd kycCid RenewKYC with
      newExpiry        = date 2028 Jan 1
      newScreeningDate = date 2027 Jan 1
  Some renewed <- queryContractId investor1 renewedCid
  assertMsg "Expiry extended"   (renewed.expiryDate == date 2028 Jan 1)
  assertMsg "Re-screening date" (renewed.lastScreeningDate == date 2027 Jan 1)
  assertMsg "Status approved"   (renewed.status == KYCApproved)

  submit bank do
    exerciseCmd renewedCid RevokeKYC
  archived <- queryContractId investor1 renewedCid
  assertMsg "KYC archived on revoke" (archived == None)
